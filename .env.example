# Root `.env` — the single canonical location for local secrets.
# Consumed by:
#   - docker-compose (Postgres + API + web services)
#   - the local API scripts (`pnpm --filter @nodea/api dev`, `seed:admin`,
#     `db:migrate`, `test`) — they all load `../../.env` relative to the
#     package directory.
#
# Two ways to fill it:
#   1. Infisical (recommended) — install the "Dev Setup" VS Code
#      extension and run `Dev Setup: Login to Infisical`. The
#      `dev-setup.yaml` at the repo root tells the extension which
#      project + environment to pull and writes the result here
#      automatically.
#   2. Manual — copy this file to `.env` (gitignored) and edit the
#      values below.

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=nodea
POSTGRES_PASSWORD=nodea_dev
POSTGRES_DB=nodea
# Host port mapped to the Postgres container. 5432 is often already taken on
# dev machines by a local server — 5433 keeps both coexisting.
POSTGRES_PORT=5433

# --- API --------------------------------------------------------------------
# REQUIRED for local dev / tests / seed. Points at the Postgres above.
DATABASE_URL=postgres://nodea:nodea_dev@127.0.0.1:5433/nodea

# REQUIRED. At least 32 characters. Signs the session cookie — rotating it
# invalidates every existing session. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# Set to `true` once the web is served behind HTTPS. Leave `false` for
# plain-HTTP local development.
COOKIE_SECURE=false

# Optional — session lifetime in seconds (default 30 days).
# SESSION_TTL_SECONDS=2592000

# --- Seed admin (pnpm --filter @nodea/api seed:admin) -----------------------
# Used once to create the first admin user. Password must be ≥ 12 chars.
# ADMIN_USERNAME is optional — if set, becomes the public display name
# shown in the UI; otherwise the UI falls back to the email local-part.
# ADMIN_EMAIL=admin@nodea.local
# ADMIN_PASSWORD=
# ADMIN_USERNAME=

# --- Password reset email ---------------------------------------------------
# Absolute URL of the web app, used to build reset links in emails.
# No trailing slash. Leave unset in local dev to get relative links.
# WEB_BASE_URL=https://nodea.example.org

# SMTP transport — all optional. When unset, the mailer logs the email
# to the API container stderr instead of sending it.
#
# Dev recipe — catch mails locally with Mailpit (web UI at
# http://localhost:8025, nothing ever leaves the machine):
#   docker compose --profile dev up -d mailpit
#   # Inside Docker:
#   SMTP_HOST=mailpit
#   # Or for `pnpm --filter @nodea/api dev` running outside Docker:
#   SMTP_HOST=127.0.0.1
#   SMTP_PORT=1025
#   SMTP_SECURE=false
#   SMTP_FROM="Nodea <dev@nodea.local>"
#
# Prod recipe — point at a real relay:
# SMTP_HOST=smtp.example.org
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# SMTP_FROM="Nodea <nodea@example.org>"

# --- Mailpit (dev SMTP sink — only used by the `dev` compose profile) ------
# MAILPIT_SMTP_PORT=1025
# MAILPIT_UI_PORT=8025

# --- Library — metadata lookup providers -----------------------------------
# Optional Google Books API key, **shared by all users on this Nodea
# instance** (one key per instance, not per user). Used by the
# `/library/lookup` proxy to fetch book metadata.
#
# When unset: the proxy still works, it just skips Google Books and
# falls back to Open Library + BNF + Wikidata + BNE — none of which
# require a key. Coverage stays excellent for FR/EN/ES literature ;
# you'll mostly notice the gap on very recent or niche editions.
#
# Get a key: https://console.cloud.google.com/apis/credentials → enable
# "Books API". Free tier ~1000 requests/day (server-side cached, so the
# real load on the key is much lower).
# LIBRARY_GOOGLE_BOOKS_API_KEY=

# --- Web --------------------------------------------------------------------
# Host port mapped to the web container (nginx on port 80 inside).
WEB_PORT=8080

# Where the SPA looks for the API. With the default Nginx reverse-proxy,
# `/api` lets both the web and the API share a single origin (no CORS).
VITE_API_URL=/api
