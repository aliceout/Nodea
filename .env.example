# Root `.env` — the single canonical location for local secrets.
# Consumed by:
#   - docker-compose (Postgres + API + web services)
#   - the local API scripts (`pnpm --filter @nodea/api dev`, `seed:admin`,
#     `db:migrate`, `test`) — they all load `../../.env` relative to the
#     package directory.
#
# Two ways to fill it:
#   1. Infisical (recommended) — install the "Dev Setup" VS Code
#      extension and run `Dev Setup: Login to Infisical`. The
#      `dev-setup.yaml` at the repo root tells the extension which
#      project + environment to pull and writes the result here
#      automatically.
#   2. Manual — copy this file to `.env` (gitignored) and edit the
#      values below.

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=nodea
POSTGRES_PASSWORD=nodea_dev
POSTGRES_DB=nodea
# Host port mapped to the Postgres container. 5432 is often already taken on
# dev machines by a local server — 5433 keeps both coexisting.
POSTGRES_PORT=5433

# --- API --------------------------------------------------------------------
# REQUIRED for local dev / tests / seed. Points at the Postgres above.
DATABASE_URL=postgres://nodea:nodea_dev@127.0.0.1:5433/nodea

# REQUIRED. At least 32 characters. Signs the session cookie — rotating it
# invalidates every existing session. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# Set to `true` once the web is served behind HTTPS. Leave `false` for
# plain-HTTP local development.
COOKIE_SECURE=false

# Optional — session lifetime in seconds.
# Legacy default = 30 days. Auth v2 (Auth-Spec.md §13) targets 7 days
# fixed (no slide). This value is read at startup; flip it once Phase 2
# of Auth-Roadmap is shipping.
# SESSION_TTL_SECONDS=604800

# --- Auth v2 — WebAuthn / Passkeys (Auth-Spec.md §13.1) -------------------
# These are read by the Auth v2 runtime (Phases 4+ of Auth-Roadmap).
# They MUST be in place before passkey enrollment can be activated;
# leaving them empty during Phases 0-3 is fine.

# Relying Party ID — typically the bare domain (no scheme, no port).
# All passkeys are bound to this exact value; CHANGING IT INVALIDATES
# EVERY ENROLLED PASSKEY (browsers refuse assertions for a different
# rpId). Pick once at launch and never touch.
# Local dev: leave as `localhost`.
# Prod: your apex domain, e.g. `nodea.app`.
# WEBAUTHN_RP_ID=localhost

# User-facing name shown in the OS / browser passkey prompts. Free text.
# WEBAUTHN_RP_NAME=Nodea

# Full origin the server expects in WebAuthn assertions (scheme + host
# + port). Must match what the client browser sees.
# Local dev (Vite): http://localhost:5173
# Prod: https://nodea.app
# WEBAUTHN_ORIGIN=http://localhost:5173

# --- Auth v2 — OPAQUE (Auth-Spec.md §13.1, Phase 2 of Auth-Roadmap) -------
# Server static setup string for @serenity-kit/opaque (Ristretto255-
# SHA512-Argon2id suite). Generate ONCE per environment with:
#   node -e "import('@serenity-kit/opaque').then(o => o.ready.then(() => \
#     console.log(o.server.createSetup())))"
# The output is a base64 string. ROTATING IT INVALIDATES EVERY OPAQUE
# ENVELOPE (issue #39 tracks the migration mechanism for this).
# OPAQUE_SERVER_SETUP=

# --- Auth v2 — Email service (Phase 1 of Auth-Roadmap) --------------------
# Picks the EmailService implementation. Auth-Spec §10.
#   - `smtp`     : real SMTP transport.
#                  Dev recipe = Mailpit (see SMTP_* block below); the
#                  rendered email lands in http://localhost:8025
#                  without ever leaving the machine. THIS IS THE DEV
#                  DEFAULT — use it whenever Docker is running.
#                  Prod recipe = Infomaniak (Infisical credentials).
#   - `recording`: in-memory store for Vitest fixtures (test only).
#   - `console`  : log JSON to stdout. Fallback only — pick this if
#                  you're running `pnpm dev` on bare metal without
#                  the dev compose-profile (so no Mailpit reachable).
# EMAIL_SERVICE_IMPL=smtp

# --- Auth v2 — Rate limit driver -------------------------------------------
# `memory` (in-process, V1 single-instance) or `redis` (future, multi-instance).
# RATE_LIMIT_DRIVER=memory

# --- Auth v2 — HSTS (Auth-Spec.md §13.1) ----------------------------------
# Sent as `Strict-Transport-Security` response header on /api responses.
# Disable in dev (HSTS over HTTP is meaningless).
# HSTS_ENABLED=false
# HSTS_MAX_AGE=31536000
# HSTS_INCLUDE_SUBDOMAINS=true
# HSTS_PRELOAD=false

# --- Seed admin (pnpm --filter @nodea/api seed:admin) -----------------------
# Used once to create the first admin user. Password must be ≥ 12 chars.
# ADMIN_USERNAME is optional — if set, becomes the public display name
# shown in the UI; otherwise the UI falls back to the email local-part.
# ADMIN_EMAIL=admin@nodea.local
# ADMIN_PASSWORD=
# ADMIN_USERNAME=

# --- Password reset email ---------------------------------------------------
# Absolute URL of the web app, used to build reset links in emails.
# No trailing slash. Leave unset in local dev to get relative links.
# WEB_BASE_URL=https://nodea.example.org

# SMTP transport — all optional. When unset, the mailer logs the email
# to the API container stderr instead of sending it.
#
# Dev recipe — catch mails locally with Mailpit (web UI at
# http://localhost:8025, nothing ever leaves the machine):
#   docker compose --profile dev up -d mailpit
#   # Inside Docker:
#   SMTP_HOST=mailpit
#   # Or for `pnpm --filter @nodea/api dev` running outside Docker:
#   SMTP_HOST=127.0.0.1
#   SMTP_PORT=1025
#   SMTP_SECURE=false
#   SMTP_FROM="Nodea <dev@nodea.local>"
#
# Prod recipe — Infomaniak (sourced via Infisical at deploy time):
# SMTP_HOST=mail.infomaniak.com
# SMTP_PORT=587                   # STARTTLS on 587, or 465 for implicit TLS
# SMTP_USER=                      # full mailbox address (Infomaniak login)
# SMTP_PASS=                      # mailbox password from Infisical
# SMTP_SECURE=false               # false for STARTTLS on 587, true for 465
# SMTP_FROM="Nodea <noreply@nodea.app>"
# SMTP_FROM_NAME=Nodea

# --- Mailpit (dev SMTP sink — only used by the `dev` compose profile) ------
# MAILPIT_SMTP_PORT=1025
# MAILPIT_UI_PORT=8025

# --- Library — metadata lookup providers -----------------------------------
# Optional Google Books API key, **shared by all users on this Nodea
# instance** (one key per instance, not per user). Used by the
# `/library/lookup` proxy to fetch book metadata.
#
# When unset: the proxy still works, it just skips Google Books and
# falls back to Open Library + BNF + Wikidata + BNE — none of which
# require a key. Coverage stays excellent for FR/EN/ES literature ;
# you'll mostly notice the gap on very recent or niche editions.
#
# Get a key: https://console.cloud.google.com/apis/credentials → enable
# "Books API". Free tier ~1000 requests/day (server-side cached, so the
# real load on the key is much lower).
# LIBRARY_GOOGLE_BOOKS_API_KEY=

# Amazon scraping adapter — runs through a headless Chromium (Puppeteer)
# to pass the AWS WAF JavaScript challenge that direct HTTP scrapers
# can't solve. Costs ~200 MB Chromium binary on disk + ~120 MB RAM idle
# + 2-5 s per lookup. Set to `false` to disable and skip the runtime
# browser entirely if you don't need Amazon (the 4 other providers
# already cover most needs). Default: true.
# LIBRARY_AMAZON_ENABLED=true

# --- Web --------------------------------------------------------------------
# Host port mapped to the web container (nginx on port 80 inside).
WEB_PORT=8080

# Where the SPA looks for the API. With the default Nginx reverse-proxy,
# `/api` lets both the web and the API share a single origin (no CORS).
VITE_API_URL=/api
