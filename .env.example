# Root `.env` — the single canonical location for local secrets.
# Consumed by:
#   - docker-compose (Postgres + API + web services)
#   - the local API scripts (`pnpm --filter @nodea/api dev`, `seed:admin`,
#     `db:migrate`, `test`) — they all load `../../.env` relative to the
#     package directory.
#
# Two ways to fill it:
#   1. Infisical (recommended) — install the "Dev Setup" VS Code
#      extension and run `Dev Setup: Login to Infisical`. The
#      `dev-setup.yaml` at the repo root tells the extension which
#      project + environment to pull and writes the result here
#      automatically.
#   2. Manual — copy this file to `.env` (gitignored) and edit the
#      values below.
#
# Running tests / the seed additionally needs:
#   - DATABASE_URL=postgres://<user>:<pass>@127.0.0.1:<port>/<db>
#   - ADMIN_EMAIL / ADMIN_PASSWORD  (seed:admin only)

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=nodea
POSTGRES_PASSWORD=nodea_dev
POSTGRES_DB=nodea
# Host port mapped to the Postgres container. 5432 is often already taken on
# dev machines by a local server — 5433 keeps both coexisting.
POSTGRES_PORT=5433

# --- API --------------------------------------------------------------------
# REQUIRED. At least 32 characters. Signs the session cookie — rotating it
# invalidates every existing session. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# Set to `true` once the web is served behind HTTPS. Leave `false` for
# plain-HTTP local development.
COOKIE_SECURE=false

# Optional — session lifetime in seconds (default 30 days).
# SESSION_TTL_SECONDS=2592000

# --- Password reset email ---------------------------------------------------
# Absolute URL of the web app, used to build reset links in emails.
# No trailing slash. Leave unset in local dev to get relative links.
# WEB_BASE_URL=https://nodea.example.org

# SMTP transport — all optional. When unset, the mailer logs the email
# to the API container stderr instead of sending it (useful in dev
# without a real SMTP server).
# SMTP_HOST=smtp.example.org
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# SMTP_FROM="Nodea <nodea@example.org>"

# --- Web --------------------------------------------------------------------
# Host port mapped to the web container (nginx on port 80 inside).
WEB_PORT=8080

# Where the SPA looks for the API. With the default Nginx reverse-proxy,
# `/api` lets both the web and the API share a single origin (no CORS).
VITE_API_URL=/api
