{
  "name": "@nodea/api",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "start": "node --env-file-if-exists=../../.env --import tsx/esm src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: pending Phase 9' && exit 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=../../.env src/db/migrate.ts",
    "db:migrate:test": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../.env.test src/db/migrate-test.ts",
    "db:studio": "drizzle-kit studio",
    "seed:admin": "tsx --env-file-if-exists=../../.env src/seed.ts",
    "seed:mood": "tsx --env-file-if-exists=../../.env src/seed-mood.ts",
    "seed:all": "pnpm seed:admin && pnpm seed:mood"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@node-rs/argon2": "^2.0.2",
    "@nodea/shared": "workspace:*",
    "@serenity-kit/opaque": "1.1.0",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "postgres": "^3.4.5",
    "puppeteer": "^24.42.0",
    "undici": "^8.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
