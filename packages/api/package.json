{
  "name": "@nodea/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env --env-file-if-exists=.env src/index.ts",
    "start": "node --env-file-if-exists=../../.env --env-file-if-exists=.env --import tsx/esm src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: pending Phase 9' && exit 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=../../.env --env-file-if-exists=.env src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "seed:admin": "tsx --env-file-if-exists=../../.env --env-file-if-exists=.env src/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@node-rs/argon2": "^2.0.2",
    "@nodea/shared": "workspace:*",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "nodemailer": "^8.0.5",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
