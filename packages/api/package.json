{
  "name": "@nodea/api",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "start": "node --env-file-if-exists=../../.env --import tsx/esm src/index.ts",
    "start:docker": "node --import tsx/esm src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=../../.env src/db/migrate.ts",
    "db:migrate:docker": "tsx src/db/migrate.ts",
    "db:migrate:test": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../.env.test src/db/migrate-test.ts",
    "db:studio": "drizzle-kit studio",
    "seed:admin": "tsx --env-file-if-exists=../../.env src/seed.ts",
    "seed:test": "tsx --env-file-if-exists=../../.env src/seed/index.ts",
    "seed:all": "pnpm seed:admin && pnpm seed:test"
  },
  "dependencies": {
    "@hono/node-server": "2.0.5",
    "@hono/swagger-ui": "0.6.1",
    "@hono/zod-openapi": "1.4.0",
    "@nodea/shared": "workspace:*",
    "@sentry/node": "10.59.0",
    "@serenity-kit/opaque": "1.1.0",
    "@simplewebauthn/server": "13.3.1",
    "drizzle-orm": "^0.45.2",
    "hono": "4.12.26",
    "node-cron": "4.5.0",
    "nodemailer": "^9.0.1",
    "otplib": "13.4.1",
    "postgres": "^3.4.9",
    "puppeteer": "25.1.0",
    "undici": "^8.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
